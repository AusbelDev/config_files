{
  "enableTelemetry": false,
  "model": "Gemini 3.5 Flash (Low)",
  "permissions": {
    "allow": [
      "mcp(KimAI/*)",
      "mcp(kimai/*)",
      "command(find)"
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "statusLine": {
    "type": "command",
    "command": "python3 {{HOME}}/.antigravity/status.py"
  },
  "title": {
    "type": "command",
    "command": "~/.gemini/antigravity-cli/title.sh",
    "enabled": true
  },
  "trustedWorkspaces": [
    "{{HOME}}",
    "{{HOME}}/LATAM/lan-jta-current-confbox",
    "{{HOME}}/.gemini",
    "{{HOME}}/mcp-kimai",
    "{{HOME}}/config_files/nvim",
    "{{HOME}}/config_files"
  ]
}