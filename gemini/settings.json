{
  "enableTelemetry": false,
  "model": "Gemini 3.5 Flash (Low)",
  "notifications": true,
  "permissions": {
    "allow": [
      "mcp(kimAI/save_user_profile)",
      "mcp(kimAI/create_outlook_timesheet)",
      "mcp(kimAI/kimai_get_user_profile)",
      "mcp(kimAI/expired_profile_data)",
      "mcp(kimAI/kimai_list_recent_timesheets)",
      "mcp(kimAI/get_available_times_in_range)",
      "mcp(kimAI/get_outlook_events)",
      "mcp(kimAI/create_timesheets)",
      "command(git status)",
      "mcp(kimAI/delete_timesheets)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 {{HOME}}/.antigravity/status.py"
  },
  "title": {
    "type": "command",
    "command": "~/.gemini/antigravity-cli/title.sh",
    "enabled": true
  },
  "trustedWorkspaces": [
    "{{HOME}}",
    "{{HOME}}/LATAM/lan-jta-current-confbox",
    "{{HOME}}/.gemini",
    "{{HOME}}/mcp-kimai",
    "{{HOME}}/config_files/nvim",
    "{{HOME}}/config_files"
  ]
}
